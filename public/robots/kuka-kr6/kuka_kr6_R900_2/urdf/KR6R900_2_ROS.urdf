    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" lower="-2.094" upper="2.094" velocity="6.772"/>
  </joint>
  <joint name="joint_a6" type="revolute">
    <origin xyz="0.09 0 0" rpy="0 0 0"/>
    <parent link="link_5"/>
    <child link="link_6"/>
    <axis xyz="-1 0 0"/>
    <limit effort="0" lower="-6.108" upper="6.108" velocity="10.734"/>
  </joint>
  <!-- ===== 固定关节 ===== -->
  <joint name="joint_a6-flange" type="fixed">
    <parent link="link_6"/>
    <child link="flange"/>
    <origin xyz="0 0 0" rpy="0 1.570796326794897 0"/>
  </joint>
  <joint name="base-base_link" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <parent link="base"/>
    <child link="base_link"/>
  </joint>
