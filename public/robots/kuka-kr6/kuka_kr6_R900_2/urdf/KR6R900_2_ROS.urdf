    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" lower="-3.316" upper="0.785" velocity="5.236"/>
  </joint>
  <joint name="joint_a3" type="revolute">
    <origin xyz="0.455 0 0" rpy="0 0 0"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit effort="0" lower="-2.094" upper="2.723" velocity="6.283"/>
