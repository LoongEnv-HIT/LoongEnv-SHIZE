<mujoco model="KUKA-KR3-SCARA">
  <compiler angle="radian" autolimits="true" inertiafromgeom="true" />
  <option gravity="0 0 0" integrator="implicitfast" />

  <default>
    <joint damping="6" armature="0.1" />
    <geom type="mesh" contype="0" conaffinity="0" rgba="1 0.5 0 1" />
    <position kp="120" />
  </default>

  <asset>
    <mesh name="base_link_mesh" file="base_link.stl" />
    <mesh name="link_1_mesh" file="link_1.stl" />
    <mesh name="link_2_mesh" file="link_2.stl" />
    <mesh name="link_3_mesh" file="link_3.stl" />
  </asset>

  <worldbody>
    <body name="base_link">
      <geom mesh="base_link_mesh" rgba="0.63 0.63 0.63 1" />

      <body name="link1" pos="0 0 0.165">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-2.5307 2.5307" />
        <geom mesh="link_1_mesh" rgba="1 0.5 0 1" />

        <body name="link2" pos="0.225 0 0.04">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-2.5307 2.5307" />
          <geom mesh="link_2_mesh" rgba="1 0.5 0 1" />

          <body name="link3" pos="0.175 0 -0.064">
            <joint name="joint3" type="slide" axis="0 0 1" range="-0.15 0" />
            <geom mesh="link_3_mesh" rgba="0.63 0.63 0.63 1" />

            <body name="link4">
              <joint name="joint4" type="hinge" axis="0 0 1" range="-3.1416 3.1416" />

              <body name="flange" euler="0 1.570796326794897 0">
                <site name="tcp" pos="0 0 0.05" size="0.02" rgba="1 0.2 0.2 0.6" group="1" />
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <position name="joint1_act" joint="joint1" />
    <position name="joint2_act" joint="joint2" />
    <position name="joint3_act" joint="joint3" />
    <position name="joint4_act" joint="joint4" />
  </actuator>
</mujoco>
